# --- Lokální vývoj (SQLite) ---
DATABASE_URL="file:./dev.db"

# --- Produkce na VPS (PostgreSQL) ---
# Změň provider v prisma/schema.prisma na "postgresql" a odkomentuj:
# DATABASE_URL="postgresql://uzivatel:heslo@localhost:5432/stavebni_denik?schema=public"

# Server
PORT=3001
CORS_ORIGIN="http://localhost:9000"

# JWT — V PRODUKCI ZMĚŇ NA DLOUHÉ NÁHODNÉ ŘETĚZCE!
JWT_ACCESS_SECRET="dev-access-secret-zmen-me-v-produkci"
JWT_REFRESH_SECRET="dev-refresh-secret-zmen-me-v-produkci"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES_DAYS=7
