# --- Stavební deník: konfigurace docker-compose stacku ---
# Zkopíruj na .env a vyplň hodnoty.

# Port, na kterém pojede aplikace (CasaOS má 80, použij jiný)
APP_PORT=9009

# Adresa, ze které se appka otvírá (uprav podle své IP/portu)
APP_ORIGIN=http://192.168.100.150:9009

# PostgreSQL
DB_USER=stavdenik
DB_PASSWORD=zmen_me_na_silne_heslo
DB_NAME=stavebni_denik

# JWT secrety — vygeneruj náhodně, např.:
#   openssl rand -hex 48
JWT_ACCESS_SECRET=vygeneruj_dlouhy_nahodny_retezec
JWT_REFRESH_SECRET=vygeneruj_jiny_dlouhy_nahodny_retezec
